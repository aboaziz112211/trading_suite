# انسخ هذا الملف إلى .env واملأ القيم
# Copy this file to .env and fill in the values

# مفتاح Gemini API — مجاني من Google AI Studio: https://aistudio.google.com/app/apikey
# (لا تشاركه ولا ترفعه على git)
GEMINI_API_KEY=

# الموقع النشط: chartedge  أو  roasting_house  (ملفات الإعداد في مجلد sites/)
SITE=chartedge

# موديل Gemini — الافتراضي سريع واقتصادي.
# بدائل: gemini-3.5-flash (الأذكى) · gemini-3.1-flash-lite (الأرخص)
MODEL=gemini-2.5-flash

# منفذ الخادم
PORT=3000
